{
  "name": "airnode-attestor",
  "version": "0.1.0",
  "type": "module",
  "license": "AGPL-3.0-only",
  "private": true,
  "scripts": {
    "dev": "node --experimental-strip-types --watch --import=./src/init-crypto.ts src/server.ts",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "fmt": "prettier . --write && eslint . --fix",
    "lint": "prettier . --check && eslint .",
    "setup": "npm install",
    "start": "node --experimental-strip-types --import=./src/init-crypto.ts src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@api3/promise-utils": "^0.4.0",
    "@reclaimprotocol/attestor-core": "^5.0.1",
    "viem": "^2.47.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.39.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-functional": "^9.0.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-unicorn": "^63.0.0",
    "globals": "^16.0.0",
    "prettier": "3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^3.0.0"
  }
}
